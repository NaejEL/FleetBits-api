# Fleet API — environment variables
# Copy to .env and fill in for local development.
# NEVER commit .env to git.

# -----------------------------------
# PostgreSQL connection string
# For local dev with Docker Compose stack:
# -----------------------------------
DATABASE_URL=postgresql+asyncpg://fleet:devpassword@localhost:5432/fleet

# -----------------------------------
# Semaphore REST API
# -----------------------------------
SEMAPHORE_URL=http://localhost:3001
SEMAPHORE_API_KEY=dev-semaphore-key
# Set these to match your Semaphore project's template IDs:
SEMAPHORE_PROJECT_ID=1
SEMAPHORE_DEPLOY_TEMPLATE_ID=1
SEMAPHORE_ROLLBACK_TEMPLATE_ID=2
SEMAPHORE_RESTART_TEMPLATE_ID=3
SEMAPHORE_DIAGNOSTICS_TEMPLATE_ID=4
SEMAPHORE_LOGS_TEMPLATE_ID=5

# -----------------------------------
# JWT signing secret (operators + CI tokens)
# Generate: openssl rand -base64 48
# -----------------------------------
FLEET_JWT_SECRET=dev-jwt-secret-change-in-production

# -----------------------------------
# Prometheus + Loki proxy URLs (for observability endpoints)
# -----------------------------------
PROMETHEUS_URL=http://localhost:9090
LOKI_URL=http://localhost:3100

# -----------------------------------
# Alertmanager internal URL
# -----------------------------------
ALERTMANAGER_URL=http://localhost:9093

# -----------------------------------
# Operator login credentials (single admin account for V1)
# -----------------------------------
OPERATOR_USERNAME=admin
OPERATOR_PASSWORD=change-me-immediately

# -----------------------------------
# Application environment
# -----------------------------------
FLEET_ENV=development

# -----------------------------------
# API base URL (used in device token generation)
# -----------------------------------
FLEET_API_URL=http://localhost:8000
